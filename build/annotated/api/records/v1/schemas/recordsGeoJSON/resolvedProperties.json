{"defs":{"0":[{"path":["length"],"id":"http://purl.org/dc/terms/extent","schema_type":"integer","sources":["bblocks://ogc.ogc-utils.json-link"],"effectiveId":"http://purl.org/dc/terms/extent"},{"path":["title"],"id":"http://www.w3.org/2000/01/rdf-schema#label","schema_type":"string","sources":["bblocks://ogc.ogc-utils.json-link"],"effectiveId":"http://www.w3.org/2000/01/rdf-schema#label"},{"path":["hreflang"],"id":"http://purl.org/dc/terms/language","schema_type":"string","sources":["bblocks://ogc.ogc-utils.json-link"],"effectiveId":"http://purl.org/dc/terms/language"},{"path":["type"],"id":"http://purl.org/dc/terms/type","schema_type":"string","sources":["bblocks://ogc.ogc-utils.json-link"],"effectiveId":"http://purl.org/dc/terms/type"},{"path":["anchor"],"schema_type":"string","sources":["bblocks://ogc.ogc-utils.json-link"]},{"path":["rel"],"id":"http://www.iana.org/assignments/relation","jsonld_type":"@id","required":true,"schema_type":"string","sources":["bblocks://ogc.ogc-utils.json-link"],"effectiveId":"http://www.iana.org/assignments/relation"},{"path":["href"],"id":"http://www.w3.org/ns/oa#hasTarget","jsonld_type":"@id","required":true,"schema_type":"string","format":"uri-reference","sources":["bblocks://ogc.ogc-utils.json-link"],"effectiveId":"http://www.w3.org/ns/oa#hasTarget"}],"1":[{"path":["dir"],"description":"The direction for text in this language. The default, `ltr`\n(left-to-right), represents the most common situation.\nHowever, care should be taken to set the value of `dir`\nappropriately if the language direction is not `ltr`.\nOther values supported are `rtl` (right-to-left), `ttb`\n(top-to-bottom), and `btt` (bottom-to-top).","schema_type":"string","enum":["ltr","rtl","ttb","btt"]},{"path":["alternate"],"description":"The name of the language in another well-understood language,\nusually English.","schema_type":"string"},{"path":["name"],"description":"The untranslated name of the language.","schema_type":"string"},{"path":["code"],"description":"The language tag as per RFC-5646.","required":true,"schema_type":"string"}],"2":[{"path":["href"],"required":true},{"path":["updated"],"id":"http://purl.org/dc/terms/modified","description":"Most recent date on which the resource pointed to by the link was changed.","schema_type":"string","format":"date-time","effectiveId":"http://purl.org/dc/terms/modified"},{"path":["created"],"id":"http://purl.org/dc/terms/created","description":"Date of creation of the resource pointed to by the link.","schema_type":"string","format":"date-time","effectiveId":"http://purl.org/dc/terms/created"},{"path":["length"],"id":"http://purl.org/dc/terms/extent","schema_type":"integer","effectiveId":"http://purl.org/dc/terms/extent"},{"path":["title"],"id":"http://www.w3.org/2000/01/rdf-schema#label","description":"Used to label the destination of a link such that it can be used as a human-readable identifier.","schema_type":"string","effectiveId":"http://www.w3.org/2000/01/rdf-schema#label"},{"path":["hreflang"],"id":"http://purl.org/dc/terms/language","description":"A hint indicating what the language of the result of dereferencing the link should be.","schema_type":"string","effectiveId":"http://purl.org/dc/terms/language"},{"path":["type"],"id":"http://purl.org/dc/terms/format","description":"A hint indicating what the media type of the result of dereferencing the link should be.","schema_type":"string","effectiveId":"http://purl.org/dc/terms/format"},{"path":["rel"],"id":"http://www.iana.org/assignments/relation","jsonld_type":"@id","description":"The type or semantics of the relation.","schema_type":"string","effectiveId":"http://www.iana.org/assignments/relation"}]},"properties":[{"path":["links"],"id":"http://www.w3.org/2000/01/rdf-schema#seeAlso","schema_type":"array","sources":["bblocks://ogc.api.features.v1.schemas.collections"],"ref":"0","effectiveId":"http://www.w3.org/2000/01/rdf-schema#seeAlso"},{"path":["collections"],"schema_type":"array","sources":["bblocks://ogc.api.features.v1.schemas.collections"]},{"path":["collections","id"],"description":"identifier of the collection used, for example, in URIs","required":true,"schema_type":"string","sources":["bblocks://ogc.api.features.v1.schemas.collection"]},{"path":["collections","title"],"description":"human readable title of the collection","schema_type":"string","sources":["bblocks://ogc.api.features.v1.schemas.collection"]},{"path":["collections","description"],"description":"a description of the features in the collection","schema_type":"string","sources":["bblocks://ogc.api.features.v1.schemas.collection"]},{"path":["collections","links"],"id":"http://www.w3.org/2000/01/rdf-schema#seeAlso","required":true,"schema_type":"array","sources":["bblocks://ogc.api.features.v1.schemas.collection"],"ref":"0","effectiveId":"http://www.w3.org/2000/01/rdf-schema#seeAlso"},{"path":["collections","extent"],"sources":["bblocks://ogc.api.features.v1.schemas.collection"]},{"path":["collections","extent","spatial"],"description":"The spatial extent of the features in the collection.","schema_type":"object","sources":["bblocks://ogc.api.features.v1.schemas.extent"]},{"path":["collections","extent","spatial","bbox"],"schema_type":"array","sources":["bblocks://ogc.api.features.v1.schemas.extent"]},{"path":["collections","extent","spatial","crs"],"description":"Coordinate reference system of the coordinates in the spatial extent\n(property `bbox`). The default reference system is WGS 84 longitude/latitude.\nIn the Core the only other supported coordinate reference system is\nWGS 84 longitude/latitude/ellipsoidal height for coordinates with height.\nExtensions may support additional coordinate reference systems and add\nadditional enum values.","schema_type":"string","enum":["http://www.opengis.net/def/crs/OGC/1.3/CRS84","http://www.opengis.net/def/crs/OGC/0/CRS84h"],"sources":["bblocks://ogc.api.features.v1.schemas.extent"]},{"path":["collections","extent","temporal"],"description":"The temporal extent of the features in the collection.","schema_type":"object","sources":["bblocks://ogc.api.features.v1.schemas.extent"]},{"path":["collections","extent","temporal","interval"],"description":"One or more time intervals that describe the temporal extent of the dataset.\nIn the Core only a single time interval is supported.\n\nExtensions may support multiple intervals.\nThe first time interval describes the overall\ntemporal extent of the data. All subsequent time intervals describe\nmore precise time intervals, e.g., to identify clusters of data.\nClients only interested in the overall temporal extent will only need\nto access the first time interval in the array (a pair of lower and upper\nbound instants).","schema_type":"array","sources":["bblocks://ogc.api.features.v1.schemas.extent"]},{"path":["collections","extent","temporal","trs"],"description":"Coordinate reference system of the coordinates in the temporal extent\n(property `interval`). The default reference system is the Gregorian calendar.\nIn the Core this is the only supported temporal coordinate reference system.\nExtensions may support additional temporal coordinate reference systems and add\nadditional enum values.","schema_type":"string","enum":["http://www.opengis.net/def/uom/ISO-8601/0/Gregorian"],"sources":["bblocks://ogc.api.features.v1.schemas.extent"]},{"path":["collections","itemType"],"description":"indicator about the type of the items in the collection (the default value is 'feature').","schema_type":"string","sources":["bblocks://ogc.api.features.v1.schemas.collection"]},{"path":["collections","crs"],"description":"the list of coordinate reference systems supported by the service","schema_type":"array","sources":["bblocks://ogc.api.features.v1.schemas.collection"]},{"path":["features"],"schema_type":"array","sources":["bblocks://ogc.api.records.v1.schemas.recordsGeoJSON"]},{"path":["features","type"],"id":"@type","required":true,"schema_type":"string","enum":["Feature"],"const":"Feature","sources":["bblocks://ogc.geo.common.data_types.geojson","bblocks://ogc.geo.features.feature"],"effectiveId":"@type"},{"path":["features","id"],"id":"@id","description":"A unique identifier of the catalog record.","required":true,"schema_type":"string","sources":["bblocks://ogc.geo.common.data_types.geojson"],"effectiveId":"@id"},{"path":["features","properties"],"id":"@nest","required":true,"schema_type":"object","sources":["bblocks://ogc.geo.common.data_types.geojson"],"effectiveId":"@nest"},{"path":["features","geometry"],"id":"https://purl.org/geojson/vocab#geometry","required":true,"sources":["bblocks://ogc.geo.common.data_types.geojson"],"effectiveId":"https://purl.org/geojson/vocab#geometry"},{"path":["features","geometry","_oneOf"],"sources":["bblocks://ogc.geo.common.data_types.geojson"],"keyword":"oneOf"},{"path":["features","geometry","_oneOf","1"],"title":"GeoJSON Point","sources":["bblocks://ogc.geo.common.data_types.geojson"],"keyword":"branch"},{"path":["features","geometry","_oneOf","1","type"],"id":"@type","required":true,"schema_type":"string","enum":["Point"],"sources":["bblocks://ogc.geo.common.data_types.geojson"],"effectiveId":"@type"},{"path":["features","geometry","_oneOf","1","coordinates"],"id":"https://purl.org/geojson/vocab#coordinates","required":true,"schema_type":"array","sources":["bblocks://ogc.geo.common.data_types.geojson"],"effectiveId":"https://purl.org/geojson/vocab#coordinates"},{"path":["features","geometry","_oneOf","1","bbox"],"id":"https://purl.org/geojson/vocab#bbox","schema_type":"array","sources":["bblocks://ogc.geo.common.data_types.geojson"],"effectiveId":"https://purl.org/geojson/vocab#bbox"},{"path":["features","geometry","_oneOf","2"],"title":"GeoJSON LineString","sources":["bblocks://ogc.geo.common.data_types.geojson"],"keyword":"branch"},{"path":["features","geometry","_oneOf","2","type"],"id":"@type","required":true,"schema_type":"string","enum":["LineString"],"sources":["bblocks://ogc.geo.common.data_types.geojson"
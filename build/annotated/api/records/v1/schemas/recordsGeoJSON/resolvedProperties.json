"},{"path":["features","geometry","_oneOf","7","geometries","_oneOf","3","type"],"id":"@type","required":true,"schema_type":"string","enum":["MultiPoint"],"sources":["bblocks://ogc.geo.common.data_types.geojson"],"effectiveId":"@type"},{"path":["features","geometry","_oneOf","7","geometries","_oneOf","4"],"title":"GeoJSON MultiLineString","sources":["bblocks://ogc.geo.common.data_types.geojson"],"keyword":"branch"},{"path":["features","geometry","_oneOf","7","geometries","_oneOf","4","type"],"id":"@type","required":true,"schema_type":"string","enum":["MultiLineString"],"sources":["bblocks://ogc.geo.common.data_types.geojson"],"effectiveId":"@type"},{"path":["features","geometry","_oneOf","7","geometries","_oneOf","5"],"title":"GeoJSON MultiPolygon","sources":["bblocks://ogc.geo.common.data_types.geojson"],"keyword":"branch"},{"path":["features","geometry","_oneOf","7","geometries","_oneOf","5","type"],"id":"@type","required":true,"schema_type":"string","enum":["MultiPolygon"],"sources":["bblocks://ogc.geo.common.data_types.geojson"],"effectiveId":"@type"},{"path":["features","geometry","_oneOf","7","bbox"],"id":"https://purl.org/geojson/vocab#bbox","schema_type":"array","sources":["bblocks://ogc.geo.common.data_types.geojson"],"effectiveId":"https://purl.org/geojson/vocab#bbox"},{"path":["features","bbox"],"id":"https://purl.org/geojson/vocab#bbox","schema_type":"array","sources":["bblocks://ogc.geo.common.data_types.geojson","bblocks://ogc.geo.features.feature"],"effectiveId":"https://purl.org/geojson/vocab#bbox"},{"path":["features","links"],"id":"http://www.w3.org/2000/01/rdf-schema#seeAlso","required":true,"schema_type":"array","sources":["bblocks://ogc.geo.features.feature"],"ref":"2","effectiveId":"http://www.w3.org/2000/01/rdf-schema#seeAlso"},{"path":["features","conformsTo"],"id":"http://purl.org/dc/terms/conformsTo","jsonld_type":"@id","schema_type":"array","effectiveId":"http://purl.org/dc/terms/conformsTo"},{"path":["features","time"],"id":"http://purl.org/dc/terms/temporal","effectiveId":"http://purl.org/dc/terms/temporal"},{"path":["features","properties","created"],"id":"http://purl.org/dc/terms/created","description":"Date of creation of this record.","schema_type":"string","format":"date-time","effectiveId":"http://purl.org/dc/terms/created"},{"path":["features","properties","updated"],"id":"http://purl.org/dc/terms/modified","description":"The most recent date on which the record was changed.","schema_type":"string","format":"date-time","effectiveId":"http://purl.org/dc/terms/modified"},{"path":["features","properties","type"],"description":"The nature or genre of the resource. The value should be a code, convenient for filtering records. Where available, a link to the canonical URI of the record type resource will be added to the 'links' property.","schema_type":"string"},{"path":["features","properties","title"],"id":"http://purl.org/dc/terms/title","description":"A human-readable name given to the resource.","schema_type":"string","effectiveId":"http://purl.org/dc/terms/title"},{"path":["features","properties","description"],"id":"http://purl.org/dc/terms/description","description":"A free-text account of the resource.","schema_type":"string","effectiveId":"http://purl.org/dc/terms/description"},{"path":["features","properties","keywords"],"id":"http://www.w3.org/ns/dcat#keyword","description":"The topic or topics of the resource. Typically represented using free-form keywords, tags, key phrases, or classification codes.","schema_type":"array","effectiveId":"http://www.w3.org/ns/dcat#keyword"},{"path":["features","properties","language"],"id":"https://www.opengis.net/def/ogc-api/records/language","description":"The language used for textual values in this record representation.","ref":"1","effectiveId":"https://www.opengis.net/def/ogc-api/records/language"},{"path":["features","properties","languages"],"id":"https://www.opengis.net/def/ogc-api/records/languages","description":"This list of languages in which this record is available.","schema_type":"array","ref":"1","effectiveId":"https://www.opengis.net/def/ogc-api/records/languages"},{"path":["features","properties","resourceLanguages"],"id":"https://www.opengis.net/def/ogc-api/records/resourceLanguages","description":"The list of languages in which the resource described by this record is available.","schema_type":"array","ref":"1","effectiveId":"https://www.opengis.net/def/ogc-api/records/resourceLanguages"},{"path":["features","properties","externalIds"],"id":"https://www.opengis.net/def/ogc-api/records/scopedIdentifier","description":"An identifier for the resource assigned by an external (to the catalog) entity.","schema_type":"array","effectiveId":"https://www.opengis.net/def/ogc-api/records/scopedIdentifier"},{"path":["features","properties","externalIds","scheme"],"id":"https://www.opengis.net/def/ogc-api/records/scheme","description":"A reference to an authority or identifier for a knowledge organization system from which the external identifier was obtained. It is recommended that the identifier be a resolvable URI.","schema_type":"string","effectiveId":"https://www.opengis.net/def/ogc-api/records/scheme"},{"path":["features","properties","externalIds","value"],"id":"https://www.opengis.net/def/ogc-api/records/id","description":"The value of the identifier.","required":true,"schema_type":"string","effectiveId":"https://www.opengis.net/def/ogc-api/records/id"},{"path":["features","properties","themes"],"id":"https://www.opengis.net/def/ogc-api/records/themes","description":"A knowledge organization system used to classify the resource.","schema_type":"array","effectiveId":"https://www.opengis.net/def/ogc-api/records/themes"},{"path":["features","properties","themes","concepts"],"id":"https://w3id.org/ogc/stac/themes/concepts","description":"One or more entity/concept identifiers from this knowledge\nsystem. it is recommended that a resolvable URI be used for\neach entity/concept identifier.","required":true,"schema_type":"array","effectiveId":"https://w3id.org/ogc/stac/themes/concepts"},{"path":["features","properties","themes","concepts","id"],"id":"https://w3id.org/ogc/stac/themes/id","description":"An identifier for the concept.","required":true,"schema_type":"string","effectiveId":"https://w3id.org/ogc/stac/themes/id"},{"path":["features","properties","themes","concepts","title"],"id":"http://purl.org/dc/terms/title","description":"A human readable title for the concept.","schema_type":"string","effectiveId":"http://purl.org/dc/terms/title"},{"path":["features","properties","themes","concepts","description"],"id":"http://purl.org/dc/terms/description","description":"A human readable description for the concept.","schema_type":"string","effectiveId":"http://purl.org/dc/terms/description"},{"path":["features","properties","themes","concepts","url"],"id":"@id","description":"A URI providing further description of the concept.","schema_type":"string","format":"uri","effectiveId":"@id"},{"path":["features","properties","themes","scheme"],"id":"https://w3id.org/ogc/stac/themes/scheme","description":"An identifier for the knowledge organization system used\nto classify the resource.  It is recommended that the\nidentifier be a resolvable URI.  The list of schemes used\nin a searchable catalog can be determined by inspecting\nthe server's OpenAPI document or, if the server implements\nCQL2, by exposing a queryable (e.g. named `scheme`) and\nenumerating the list of schemes in the queryable's schema\ndefinition.","required":true,"schema_type":"string","effectiveId":"https://w3id.org/ogc/stac/themes/scheme"},{"path":["features","properties","formats"],"id":"https://www.opengis.net/def/ogc-api/records/format","jsonld_type":"@id","description":"A list of available distributions of the resource.","schema_type":"array","effectiveId":"https://www.opengis.net/def/ogc-api/records/format"},{"path":["features","properties","formats","name"],"id":"https://www.opengis.net/def/ogc-api/records/name","schema_type":"string","effectiveId":"https://www.opengis.net/def/ogc-api/records/name"},{"path":["features","properties","formats","mediaType"],"id":"https://www.opengis.net/def/ogc-api/records/mediaType","schema_type":"string","effectiveId":"https://www.opengis.net/def/ogc-api/records/mediaType"},{"path":["features","properties","contacts"],"id":"http://www.w3.org/ns/dcat#contactPoint","jsonld_type":"@id","description":"A list of contacts qualified by their role(s) in association to the record or the resource described by the record.","schema_type":"array","effectiveId":"http://www.w3.org/ns/dcat#contactPoint"},{"path":["features","properties","contacts","identifier"],"description":"A value uniquely identifying a contact.","schema_type":"string"},{"path":["features","properties","contacts","name"],"description":"The name of the responsible person.","schema_type":"string"},{"path":["features","properties","contacts","position"],"description":"The name of the role or position of the responsible person taken from the organization's formal organizational hierarchy or chart.","schema_type":"string"},{"path":["features","properties","contacts","organization"],"description":"Organization/affiliation of the contact.","schema_type":"string"},{"path":["features","properties","contacts","logo"],"description":"Graphic identifying a contact. The link relation should be `icon` and the media type should be an image media type.","ref":"0"},{"path":["features","properties","contacts","logo","rel"],"required":true,"enum":["icon"]},{"path":["features","properties","contacts","phones"],"description":"Telephone numbers at which contact can be made.","schema_type":"array"},{"path":["features","properties","contacts","phones","value"],"description":"The value is the phone number itself.","required":true,"schema_type":"string"},{"path":["features","properties","contacts","phones","roles"],"description":"The type of phone number (e.g. home, work, fax, etc.)."},{"path":["features","properties","contacts","emails"],"description":"Email addresses at which contact can be made.","schema_type":"array"},{"path":["features","properties","contacts","emails","value"],"description":"The value is the email number itself.","required":true,"schema_type":"string","format":"email"},{"path":["features","properties","contacts","emails","roles"],"description":"The type of email (e.g. home, work, etc.)."},{"path":["features","properties","contacts","addresses"],"description":"Physical location at which contact can be made.","schema_type":"array"},{"path":["features","properties","contacts","addresses","deliveryPoint"],"description":"Address lines for the location.","schema_type":"array"},{"path":["features","properties","contacts","addresses","city"],"description":"City for the location.","schema_type":"string"},{"path":["features","properties","contacts","addresses","administrativeArea"],"description":"State or province of the location.","schema_type":"string"},{"path":["features","properties","contacts","addresses","postalCode"],"description":"ZIP or other postal code.","schema_type":"string"},{"path":["features","properties","contacts","addresses","country"],"description":"Country of the physical address.  ISO 3166-1 is recommended.","schema_type":"string"},{"path":["features","properties","contacts","addresses","roles"],"description":"The type of address (e.g. office, home, etc.)."},{"path":["features","properties","contacts","links"],"description":"On-line information about the contact.","schema_type":"array","ref":"0"},{"path":["features","properties","contacts","hoursOfService"],"description":"Time period when the contact can be contacted.","schema_type":"string"},{"path":["features","properties","contacts","contactInstructions"],"description":"Supplemental instructions on how or when to contact the\nresponsible party.","schema_type":"string"},{"path":["features","properties","contacts","roles"],"description":"The set of named duties, job functions